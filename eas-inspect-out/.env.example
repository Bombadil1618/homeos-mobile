# Copy to .env and fill in. Used for Google OAuth and API base URL.
# Expo exposes only variables prefixed with EXPO_PUBLIC_ to the app.

# Same Google OAuth Web client ID as the Vercel backend (from Google Cloud Console).
# Add the Expo proxy redirect URI (https://auth.expo.io/...) to that client's authorized redirect URIs.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# Backend base URL for code exchange (no trailing slash). Dev: http://localhost:3000 or your tunnel URL.
EXPO_PUBLIC_API_URL=http://localhost:3000

# PowerSync service endpoint URL (no trailing slash). From PowerSync Dashboard or self-hosted instance.
EXPO_PUBLIC_POWERSYNC_URL=
